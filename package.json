{
  "name": "otak-usage",
  "displayName": "otak-usage",
  "description": "%extension.description%",
  "version": "1.8.3",
  "publisher": "odangoo",
  "license": "MIT",
  "icon": "./images/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/tsuyoshi-otake/otak-usage"
  },
  "bugs": {
    "url": "https://github.com/tsuyoshi-otake/otak-usage/issues"
  },
  "homepage": "https://github.com/tsuyoshi-otake/otak-usage#readme",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "extensionKind": [
    "workspace",
    "ui"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "otak-usage.cycleStatusBarView",
        "title": "%command.cycleStatusBarView%",
        "category": "Otak Usage"
      },
      {
        "command": "otak-usage.togglePeriod",
        "title": "%command.togglePeriod%",
        "category": "Otak Usage"
      },
      {
        "command": "otak-usage.refresh",
        "title": "%command.refresh%",
        "category": "Otak Usage"
      },
      {
        "command": "otak-usage.copyUsage",
        "title": "%command.copyUsage%",
        "category": "Otak Usage"
      }
    ],
    "configuration": {
      "title": "otak-usage",
      "properties": {
        "otakUsage.period": {
          "type": "string",
          "enum": [
            "today",
            "month"
          ],
          "default": "today",
          "description": "%config.period%"
        },
        "otakUsage.updateIntervalSeconds": {
          "type": "number",
          "default": 60,
          "minimum": 10,
          "description": "%config.updateIntervalSeconds%"
        },
        "otakUsage.dailyAlertThresholdUsd": {
          "type": "number",
          "default": 10,
          "minimum": 0,
          "description": "%config.dailyAlertThresholdUsd%"
        },
        "otakUsage.showClaude": {
          "type": "boolean",
          "default": true,
          "description": "%config.showClaude%"
        },
        "otakUsage.showCodex": {
          "type": "boolean",
          "default": true,
          "description": "%config.showCodex%"
        },
        "otakUsage.showRateLimits": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "%config.showRateLimits%"
        },
        "otakUsage.statusBarMode": {
          "type": "string",
          "enum": [
            "cost",
            "limits",
            "costAndLimits"
          ],
          "enumDescriptions": [
            "Show only the API-equivalent cost.",
            "Show only subscription rate-limit usage; falls back to cost until a snapshot is available.",
            "Show cost followed by rate-limit usage."
          ],
          "default": "cost",
          "description": "%config.statusBarMode%"
        },
        "otakUsage.showRtk": {
          "type": "boolean",
          "default": true,
          "description": "%config.showRtk%"
        },
        "otakUsage.rtkPath": {
          "type": "string",
          "default": "",
          "description": "%config.rtkPath%"
        },
        "otakUsage.pricingOverrides": {
          "type": "object",
          "default": {},
          "markdownDescription": "%config.pricingOverrides%",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "input": {
                "type": "number"
              },
              "output": {
                "type": "number"
              },
              "cacheWrite": {
                "type": "number"
              },
              "cacheRead": {
                "type": "number"
              },
              "cachedInput": {
                "type": "number"
              }
            }
          }
        },
        "otakUsage.claudeConfigDir": {
          "type": "string",
          "default": "",
          "description": "%config.claudeConfigDir%"
        },
        "otakUsage.codexHome": {
          "type": "string",
          "default": "",
          "description": "%config.codexHome%"
        },
        "otakUsage.telemetry.enabled": {
          "type": "boolean",
          "default": false,
          "description": "%config.telemetryEnabled%"
        },
        "otakUsage.telemetry.includeTokenUsage": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "%config.telemetryIncludeTokenUsage%"
        },
        "otakUsage.telemetry.includeCost": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "%config.telemetryIncludeCost%"
        },
        "otakUsage.telemetry.includeRtkTokens": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "%config.telemetryIncludeRtkTokens%"
        },
        "otakUsage.telemetry.endpoint": {
          "type": "string",
          "default": "http://localhost:4318",
          "markdownDescription": "%config.telemetryEndpoint%"
        },
        "otakUsage.telemetry.headers": {
          "type": "object",
          "default": {},
          "additionalProperties": {
            "type": "string"
          },
          "markdownDescription": "%config.telemetryHeaders%"
        },
        "otakUsage.telemetry.serviceName": {
          "type": "string",
          "default": "otak-usage",
          "description": "%config.telemetryServiceName%"
        },
        "otakUsage.telemetry.serviceInstanceId": {
          "type": "string",
          "default": "",
          "description": "%config.telemetryServiceInstanceId%"
        }
      }
    },
    "icons": {
      "otak-openai": {
        "description": "OpenAI logo (Codex CLI)",
        "default": {
          "fontPath": "./images/otak-usage-icons.woff",
          "fontCharacter": "\\E900"
        }
      },
      "otak-claude": {
        "description": "Claude logo (Claude Code)",
        "default": {
          "fontPath": "./images/otak-usage-icons.woff",
          "fontCharacter": "\\E901"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test",
    "package": "vsce package",
    "package:vsix": "vsce package",
    "deploy": "vsce publish --skip-duplicate"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "20.x",
    "@types/vscode": "1.90.0",
    "@typescript-eslint/eslint-plugin": "^8.22.0",
    "@typescript-eslint/parser": "^8.22.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.4.1",
    "@vscode/vsce": "^3.6.0",
    "eslint": "^9.19.0",
    "typescript": "^5.7.3"
  }
}

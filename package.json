{
  "name": "otak-usage",
  "displayName": "otak-usage",
  "description": "%extension.description%",
  "version": "1.2.3",
  "publisher": "odangoo",
  "license": "MIT",
  "icon": "./images/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/tsuyoshi-otake/otak-usage"
  },
  "bugs": {
    "url": "https://github.com/tsuyoshi-otake/otak-usage/issues"
  },
  "homepage": "https://github.com/tsuyoshi-otake/otak-usage#readme",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "extensionKind": [
    "workspace",
    "ui"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "otak-usage.togglePeriod",
        "title": "%command.togglePeriod%",
        "category": "Otak Usage"
      },
      {
        "command": "otak-usage.refresh",
        "title": "%command.refresh%",
        "category": "Otak Usage"
      },
      {
        "command": "otak-usage.copyUsage",
        "title": "%command.copyUsage%",
        "category": "Otak Usage"
      }
    ],
    "configuration": {
      "title": "otak-usage",
      "properties": {
        "otakUsage.period": {
          "type": "string",
          "enum": [
            "today",
            "month"
          ],
          "default": "today",
          "description": "%config.period%"
        },
        "otakUsage.updateIntervalSeconds": {
          "type": "number",
          "default": 60,
          "minimum": 10,
          "description": "%config.updateIntervalSeconds%"
        },
        "otakUsage.dailyAlertThresholdUsd": {
          "type": "number",
          "default": 10,
          "minimum": 0,
          "description": "%config.dailyAlertThresholdUsd%"
        },
        "otakUsage.showClaude": {
          "type": "boolean",
          "default": true,
          "description": "%config.showClaude%"
        },
        "otakUsage.showCodex": {
          "type": "boolean",
          "default": true,
          "description": "%config.showCodex%"
        },
        "otakUsage.showRtk": {
          "type": "boolean",
          "default": true,
          "description": "%config.showRtk%"
        },
        "otakUsage.rtkPath": {
          "type": "string",
          "default": "",
          "description": "%config.rtkPath%"
        },
        "otakUsage.pricingOverrides": {
          "type": "object",
          "default": {},
          "markdownDescription": "%config.pricingOverrides%",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "input": {
                "type": "number"
              },
              "output": {
                "type": "number"
              },
              "cacheWrite": {
                "type": "number"
              },
              "cacheRead": {
                "type": "number"
              },
              "cachedInput": {
                "type": "number"
              }
            }
          }
        },
        "otakUsage.claudeConfigDir": {
          "type": "string",
          "default": "",
          "description": "%config.claudeConfigDir%"
        },
        "otakUsage.codexHome": {
          "type": "string",
          "default": "",
          "description": "%config.codexHome%"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/vscode": "1.90.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "20.x",
    "@typescript-eslint/eslint-plugin": "^8.22.0",
    "@typescript-eslint/parser": "^8.22.0",
    "eslint": "^9.19.0",
    "typescript": "^5.7.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.4.1",
    "@vscode/vsce": "^3.6.0"
  }
}
